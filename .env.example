# ── Atlassian (Jira + Confluence) ─────────────────────────────────────────────
# Used by: scripts/create_rea_jira.py, scripts/create_confluence_pages.py,
#          scripts/push_decisions_confluence.py
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
JIRA_BASE=https://your-org.atlassian.net
CONFLUENCE_BASE=https://your-org.atlassian.net/wiki

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@host:5432/realestateagent
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
SECRET_KEY=your-secret-key-min-32-chars
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODEL_ID=blissful_ishizaka_626/gemma4-cloud
OPENROUTER_API_KEY=your-openrouter-api-key
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=real-estate-agent

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ── Object Storage (Cloudflare R2) ───────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=real-estate-agent-docs
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── CRM ───────────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
HUBSPOT_API_KEY=your-hubspot-api-key

# ── Email / SMS ───────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Maps ──────────────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=your-mapbox-public-token

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
